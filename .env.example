DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
PORT=3001
CORS_ORIGIN=*

# MWGL 鲁棒生成（借鉴 RobustFlow：多样本 + 校验择优 + 修复重试）
# MWGL_ROBUST=0 关闭，仅单次调用
MWGL_ROBUST=1
MWGL_ROBUST_SAMPLES=3
MWGL_ROBUST_REPAIR_MAX=2
# MWGL_ROBUST_ENSEMBLE=0 多个合法候选时不调用评审，直接取低温样本优先
MWGL_ROBUST_ENSEMBLE=1

# Python 工具 eval_mwgl_robustness.py 已在代码内默认 HF_ENDPOINT=https://hf-mirror.com
# 其它自行运行的 huggingface-cli / Python 下载模型时可手动设置：
# export HF_ENDPOINT=https://hf-mirror.com
